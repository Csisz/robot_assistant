CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_OFFSET=0x8000

# LCD module selection
CONFIG_WAVESHARE_2_8INCH_TOUCH_LCD=y

# Display rotation: 90 degrees (landscape 320x240)
CONFIG_EXAMPLE_DISPLAY_ROTATION_90_DEGREE=y

# PSRAM / SPIRAM (required for LVGL DMA buffers)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_FETCH_INSTRUCTIONS=y
CONFIG_SPIRAM_RODATA=y

# Reserve 64 KB of internal DMA-capable RAM so SDMMC, I2S, and JPEG DMA
# allocations always have headroom even when SPIRAM malloc is under pressure.
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=65536

# Product mode defaults
CONFIG_ROBOT_ENABLE_KIDS_CHAT=y
# CONFIG_ROBOT_ENABLE_VOICE_INPUT is not set
# CONFIG_ROBOT_ENABLE_VOICE_WEB_ROUTE is not set
CONFIG_ROBOT_CHAT_BACKEND_HOST="192.168.1.234"
CONFIG_ROBOT_CHAT_BACKEND_PORT=8000
CONFIG_ROBOT_CHAT_BACKEND_PATH="/api/robot/chat"
CONFIG_ROBOT_CHAT_DEVICE_ID="robot_assistant_esp32s3"
CONFIG_ROBOT_CHAT_LOCALE="hu-HU"
